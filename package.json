{
  "name": "@siberiacancode/root",
  "version": "0.0.0",
  "description": "Ultimate tool",
  "author": {
    "name": "SIBERIA CAN CODE 🧊",
    "url": "https://github.com/siberiacancode"
  },
  "license": "MIT",
  "homepage": "https://siberiacancode.github.io/reactuse/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siberiacancode/reactuse.git"
  },
  "bugs": "https://github.com/siberiacancode/reactuse/issues",
  "keywords": [
    "react",
    "react hooks",
    "react use",
    "use",
    "hooks"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "cli:build": "pnpm --dir packages/cli build && pnpm --dir packages/cli generate-registry",
    "cli:build:registry": "pnpm --dir packages/cli build:registry",
    "docs:build": "pnpm --dir packages/newdocs build",
    "core:build:js": "pnpm --dir packages/core build:js",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write .",
    "unit-test": "pnpm --recursive run unit-test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@siberiacancode/tsconfig": "1.2.0",
    "@siberiacancode/eslint": "2.17.6",
    "@siberiacancode/prettier": "^1.7.0",
    "@types/node": "^26.1.0",
    "lefthook": "^2.1.9",
    "lucide-react": "1.23.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "^6.0.3"
  }
}
