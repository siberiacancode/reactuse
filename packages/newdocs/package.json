{
  "name": "@siberiacancode/docs",
  "version": "1.0.0",
  "description": "Ultimate tool",
  "author": {
    "name": "SIBERIA CAN CODE 🧊",
    "url": "https://github.com/siberiacancode"
  },
  "license": "MIT",
  "homepage": "https://siberiacancode.github.io/reactuse/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siberiacancode/reactuse.git",
    "directory": "packages/newdocs"
  },
  "bugs": "https://github.com/siberiacancode/reactuse/issues",
  "keywords": [
    "react",
    "react hooks",
    "react use",
    "use",
    "hooks"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "pnpm next dev --turbopack --port 4000",
    "build": "next build",
    "start": "next start --port 4000",
    "preview": "next build && next start --port 4000",
    "lint": "eslint . --fix",
    "lint-inspector": "npx @eslint/config-inspector@latest",
    "format": "prettier --write .",
    "type": "tsc --noEmit",
    "pretty": "pnpm type && pnpm lint && pnpm format",
    "predev": "pnpm run generate:functions && pnpm run generate:static && fumadocs-mdx",
    "prebuild": "pnpm run generate:functions && pnpm run generate:static && pnpm run generate:registry && fumadocs-mdx",
    "postinstall": "fumadocs-mdx",
    "generate:functions": "bun run scripts/generate-functions.ts",
    "generate:static": "bun run scripts/generate-static.ts",
    "generate:registry": "bun run scripts/generate-registry.ts",
    "sync:content": "bun run scripts/sync-content.ts",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@siberiacancode/fetches": "^1.14.3",
    "@siberiacancode/reactuse": "^0.3.48",
    "@types/mdx": "^2.0.14",
    "algoliasearch": "^5.55.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "comment-parser": "^1.4.7",
    "fumadocs-core": "16.10.5",
    "fumadocs-docgen": "3.0.10",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-typescript": "^5.2.6",
    "fumadocs-ui": "16.10.5",
    "lru-cache": "^11.5.1",
    "lucide-react": "1.21.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "npm-to-yarn": "^3.0.1",
    "postcss": "^8.5.15",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-element-to-jsx-string": "^17.0.1",
    "rehype-pretty-code": "^0.14.3",
    "remark": "^15.0.1",
    "rimraf": "^6.1.3",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shikijs/rehype": "^4.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/dom-speech-recognition": "^0.0.12",
    "@types/node": "26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-bluetooth": "^0.0.21",
    "md5": "^2.3.0",
    "ora": "^9.4.0",
    "tailwindcss": "^4.3.1",
    "tsconfig-paths": "^4.2.0"
  },
  "lint-staged": {
    "*.{md,mdx,*ts,*js,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
