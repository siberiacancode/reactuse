{
  "compilerOptions": {
    "incremental": true,
    "target": "esnext",
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/utils/lib": ["./src/lib"],
      "@/*": ["./*"],
      "@siberiacancode/docs": ["."],
      "@siberiacancode/docs/*": ["./*"],
      "@siberiacancode/docs/utils": ["./utils.ts"],
      "@docs/*": ["./*"],
      "@siberiacancode/reactuse": ["../core/src/dist/esm/index.mjs"]
    },
    "resolveJsonModule": true,
    "types": ["@types/web-bluetooth", "@types/dom-speech-recognition"],
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "newLine": "lf",
    "noEmit": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["dist", "node_modules", "**/*.demo.*"]
}
